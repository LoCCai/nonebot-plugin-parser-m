<!DOCTYPE html>
<html lang="zh-CN">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Tieba Post</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    @import url("https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@400;500;700&family=Segoe+UI:wght@400;600;700&display=swap");

    :root {
      --primary-color: #1e88e5;
      --secondary-color: #42a5f5;
      --dark-color: #2c3e50;
      --light-color: #ecf0f1;
      --gray-color: #95a5a6;
      --border-radius: 12px;
      --box-shadow: 0 8px 25px rgba(0, 0, 0, 0.08);
      --transition: all 0.3s ease;
    }
    
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Segoe UI', 'Noto Sans SC', sans-serif;
    }
    
    body {
      display: flex;
      justify-content: center;
      align-items: flex-start;
      min-height: 100vh;
      background: transparent;
      padding: 20px;
    }

    .card {
      width: 750px;
      background-color: white;
      border-radius: var(--border-radius);
      box-shadow: var(--box-shadow);
      overflow: hidden;
      position: relative;
      margin-bottom: 20px;
      border: 1px solid rgba(0, 0, 0, 0.02);
    }

    .decorative-stripe {
      position: absolute;
      width: 100%;
      height: 5px;
      background: linear-gradient(90deg, var(--primary-color) 0%, var(--secondary-color) 50%, #9b59b6 100%);
      top: 0;
      left: 0;
      z-index: 5;
    }

    .content-section {
      padding: 30px;
    }

    .header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 25px;
      padding-bottom: 20px;
      border-bottom: 1px dashed #eee;
    }

    .author-info {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .avatar {
      width: 64px;
      height: 64px;
      border-radius: 4px;
      object-fit: cover;
      border: 3px solid #fff;
      box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    }

    .user-info {
      display: flex;
      flex-direction: column;
      flex: 1;
    }

    .username {
      font-size: 19px;
      font-weight: bold;
      color: var(--dark-color);
      margin-bottom: 6px;
    }

    .time {
      font-size: 13px;
      color: var(--gray-color);
      margin-bottom: 4px;
      display: flex;
      align-items: center;
      gap: 4px;
    }

    .time::before {
      content: "\f017";
      font-family: "Font Awesome 6 Free";
      font-weight: 400;
    }

    .forum-name {
      font-size: 13px;
      color: #555;
      background-color: #f1f8ff;
      padding: 2px 8px;
      border-radius: 6px;
      align-self: flex-start;
    }

    .platform-logo {
      height: 32px;
      margin-left: 16px;
    }

    .title {
      font-size: 22px;
      font-weight: bold;
      margin: 16px 0;
      color: var(--dark-color);
      line-height: 1.4;
      padding-left: 12px;
      border-left: 4px solid var(--secondary-color);
    }

    .text {
      font-size: 15px;
      line-height: 1.7;
      color: #444;
      margin-bottom: 20px;
      white-space: pre-wrap;
    }

    /* 图片展示区域 */
    .images-container {
      margin: 20px 0;
    }

    .images-header {
      font-size: 14px;
      color: var(--dark-color);
      font-weight: 600;
      margin-bottom: 10px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .images-header i {
      color: #2ecc71;
    }

    .images-grid {
      display: grid;
      gap: 6px;
      width: 100%;
      border-radius: 8px;
      overflow: hidden;
    }

    .images-grid.single {
      grid-template-columns: 1fr;
    }

    .images-grid.single .image-item {
      max-height: none;
    }

    .images-grid.double {
      grid-template-columns: 1fr 1fr;
    }

    .images-grid.double .image-item {
      aspect-ratio: 16/9;
    }

    .images-grid.quad {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: 1fr 1fr;
    }

    .images-grid.quad .image-item {
      aspect-ratio: 1/1;
    }

    .images-grid.nine {
      grid-template-columns: repeat(3, 1fr);
    }

    .images-grid.nine .image-item {
      aspect-ratio: 1/1;
    }

    .image-item {
      position: relative;
      overflow: hidden;
      background: #eee;
    }

    .image-item img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .more-count {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: rgba(0, 0, 0, 0.5);
      backdrop-filter: blur(2px);
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 28px;
      font-weight: bold;
    }

    /* 评论区域 */
    .comments-section {
      padding: 0 30px 30px;
      border-top: 1px solid #eee;
      margin-top: 20px;
    }
    
    .comments-header {
      font-size: 18px;
      font-weight: 700;
      color: var(--dark-color);
      margin: 20px 0;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    
    .comments-header i {
      color: var(--secondary-color);
    }
    
    /* 主评论容器 */
    .comment-container {
      display: flex;
      gap: 12px;
      margin-bottom: 20px;
      padding-bottom: 20px;
      border-bottom: 1px dashed #eee;
    }
    
    .comment-container:last-child {
      border-bottom: none;
      margin-bottom: 0;
      padding-bottom: 0;
    }
    
    /* 头像区域 */
    .comment-avatar-wrapper {
      flex-shrink: 0;
      width: 48px;
      height: 48px;
    }
    
    .comment-avatar {
      width: 100%;
      height: 100%;
      border-radius: 50%;
      object-fit: cover;
      border: 2px solid #f0f0f0;
    }
    
    /* 评论内容区域 */
    .comment-content-wrapper {
      flex: 1;
      min-width: 0;
    }
    
    /* 作者信息行 */
    .comment-author-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 8px;
    }
    
    .comment-author-info {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
      flex: 1;
    }
    
    .comment-author-name {
      font-weight: 600;
      font-size: 14px;
      color: var(--dark-color);
      line-height: 1.2;
    }
    
    /* 评论时间 */
    .comment-time {
      font-size: 12px;
      color: var(--gray-color);
      white-space: nowrap;
      margin-left: 8px;
    }
    
    /* 评论内容 */
    .comment-text {
      font-size: 14px;
      line-height: 1.6;
      color: #444;
      margin-bottom: 10px;
      word-wrap: break-word;
    }
    
    /* 统计信息 */
    .comment-stats {
      display: flex;
      gap: 16px;
      font-size: 12px;
      color: var(--gray-color);
    }
    
    .comment-stat {
      display: flex;
      align-items: center;
      gap: 4px;
    }
    
    /* 回复样式 */
    .comment-replies {
      margin-top: 15px;
      margin-left: 12px;
      padding-left: 48px;
      border-left: 2px solid #f0f0f0;
    }
    
    .reply-container {
      display: flex;
      gap: 12px;
      margin-bottom: 15px;
      padding-bottom: 15px;
      border-bottom: 1px dashed #f0f0f0;
    }
    
    .reply-container:last-child {
      border-bottom: none;
      margin-bottom: 0;
      padding-bottom: 0;
    }
    
    /* 回复头像区域 */
    .reply-avatar-wrapper {
      flex-shrink: 0;
      width: 40px;
      height: 40px;
      margin-top: 2px;
    }
    
    .reply-avatar {
      width: 100%;
      height: 100%;
      border-radius: 50%;
      object-fit: cover;
      border: 2px solid #f0f0f0;
    }
    
    /* 回复内容区域 */
    .reply-content-wrapper {
      flex: 1;
      min-width: 0;
    }
    
    /* 回复作者信息行 */
    .reply-author-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 6px;
    }
    
    .reply-author-info {
      display: flex;
      align-items: center;
      gap: 6px;
      flex-wrap: wrap;
      flex: 1;
    }
    
    .reply-author-name {
      font-weight: 600;
      font-size: 13px;
      color: var(--dark-color);
      line-height: 1.2;
    }
    
    /* 回复时间 */
    .reply-time {
      font-size: 11px;
      color: var(--gray-color);
      white-space: nowrap;
      margin-left: 6px;
    }
    
    /* 回复内容 */
    .reply-text {
      font-size: 13px;
      line-height: 1.5;
      color: #555;
      margin-bottom: 8px;
      word-wrap: break-word;
    }

    /* 处理评论中的图片 */
    .comment-text img {
      max-width: 100%;
      height: auto;
      border-radius: 8px;
      margin: 5px 0;
    }

    /* 处理回复中的图片 */
    .reply-text img {
      max-width: 100%;
      height: auto;
      border-radius: 6px;
      margin: 4px 0;
    }

    /* 处理表情 */
    .sticker {
      vertical-align: middle;
      margin: 0 2px;
    }

    .sticker.small {
      width: 24px;
      height: 24px;
    }

    /* 底部信息栏 */
    .footer-section {
      background-color: var(--dark-color);
      color: rgba(255,255,255,0.8);
      padding: 15px 30px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 12px;
    }
    
    .footer-brand {
      font-weight: 600;
      letter-spacing: 0.5px;
      color: white;
      display: flex;
      gap: 8px;
      align-items: center;
    }
    
    .footer-info {
      display: flex;
      gap: 15px;
      align-items: center;
    }
  </style>
</head>

<body>

  <div class="card">
    <div class="decorative-stripe"></div>
    
    <div class="content-section">
      <div class="header">
        <div class="author-info">
          <img src="{{ result.author.avatar_path }}" class="avatar" alt="avatar" />
          <div class="user-info">
            <div class="username">{{ result.author.name }}</div>
            <div class="time">{{ result.formatted_datetime }}</div>
            <div class="forum-name">{{ result.extra.forum.name }}吧</div>
          </div>
        </div>
        <img src="{{ result.platform.logo_path }}" class="platform-logo" alt="{{ result.platform.display_name }}" />
      </div>

      {% if result.title %}
      <div class="title">{{ result.title }}</div>
      {% endif %}

      {% if result.text %}
      <div class="text">{{ result.text | e | replace("\n", "<br>") | safe }}</div>
      {% endif %}

      {% if result.img_contents %}
      <div class="images-container">
        <div class="images-header">
          <i class="fas fa-images"></i> 内容图片
        </div>
        {% set imgs = result.img_contents %}
        {% set count = imgs|length %}
        {% set grid_class = 'single' %}
        {% if count == 2 %}{% set grid_class = 'double' %}
        {% elif count == 4 %}{% set grid_class = 'quad' %}
        {% elif count >= 3 %}{% set grid_class = 'nine' %}
        {% endif %}
        <div class="images-grid {{ grid_class }}">
          {% for img in imgs[:9] %}
          <div class="image-item">
            <img src="{{ img.path }}" alt="image" />
            {% if loop.last and count > 9 %}
            <div class="more-count">+{{ count - 9 }}</div>
            {% endif %}
          </div>
          {% endfor %}
        </div>
      </div>
      {% endif %}

      {% if result.graphics_contents %}
      <div class="images-container">
        <div class="images-header">
          <i class="fas fa-images"></i> 内容图片
        </div>
        {% set imgs = result.graphics_contents %}
        {% set count = imgs|length %}
        {% set grid_class = 'single' %}
        {% if count == 2 %}{% set grid_class = 'double' %}
        {% elif count == 4 %}{% set grid_class = 'quad' %}
        {% elif count >= 3 %}{% set grid_class = 'nine' %}
        {% endif %}
        <div class="images-grid {{ grid_class }}">
          {% for g in imgs[:9] %}
          <div class="image-item">
            <img src="{{ g.path }}" alt="graphics" />
            {% if loop.last and count > 9 %}
            <div class="more-count">+{{ count - 9 }}</div>
            {% endif %}
          </div>
          {% endfor %}
        </div>
      </div>
      {% endif %}
    </div>

    <!-- 评论区域 -->
    {% set comments = result.extra.comments if result.extra.comments else [] %}
    {% if comments and comments|length > 0 %}
    <div class="comments-section">
      <div class="comments-header">
        <i class="fas fa-comments"></i> 评论 ({{ comments|length }})
      </div>
      
      {% for comment in comments %}
      <div class="comment-container">
        <!-- 左侧头像 -->
        <div class="comment-avatar-wrapper">
          <img src="{{ comment.author.avatar }}" alt="用户头像" class="comment-avatar">
        </div>
        
        <!-- 右侧内容 -->
        <div class="comment-content-wrapper">
          <!-- 作者信息行 -->
          <div class="comment-author-row">
            <div class="comment-author-info">
              <span class="comment-author-name">{{ comment.author.name }}</span>
            </div>
            <span class="comment-time">{{ comment.formatted_time }}</span>
          </div>
          
          <!-- 评论内容 -->
          <div class="comment-text">
            {{ comment.content | safe }}
          </div>
          
          <!-- 统计信息 -->
          <div class="comment-stats">
            {% if comment.ups %}
            <span class="comment-stat">
              <i class="fas fa-thumbs-up"></i>
              <span>{{ comment.ups }}</span>
            </span>
            {% endif %}
            {% if comment.comments %}
            <span class="comment-stat">
              <i class="fas fa-reply"></i>
              <span>{{ comment.comments }}</span>
            </span>
            {% endif %}
          </div>
          
          <!-- 回复列表 -->
          {% if comment.child_posts and comment.child_posts|length > 0 %}
          <div class="comment-replies">
            {% for reply in comment.child_posts %}
            <div class="reply-container">
              <!-- 回复左侧头像 -->
              <div class="reply-avatar-wrapper">
                <img src="{{ reply.author.avatar }}" alt="回复者头像" class="reply-avatar">
              </div>
              
              <!-- 回复右侧内容 -->
              <div class="reply-content-wrapper">
                <!-- 回复作者信息行 -->
                <div class="reply-author-row">
                  <div class="reply-author-info">
                    <span class="reply-author-name">{{ reply.author.name }}</span>
                  </div>
                  <span class="reply-time">{{ reply.formatted_time }}</span>
                </div>
                
                <!-- 回复内容 -->
                <div class="reply-text">
                  {{ reply.content | safe }}
                </div>
                
                <!-- 回复统计信息 -->
                <div class="comment-stats">
                  {% if reply.ups %}
                  <span class="comment-stat">
                    <i class="fas fa-thumbs-up"></i>
                    <span>{{ reply.ups }}</span>
                  </span>
                  {% endif %}
                </div>
              </div>
            </div>
            {% endfor %}
          </div>
          {% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
    {% endif %}

    <!-- 底部 -->
    <div class="footer-section">
      <div class="footer-brand">
        <i class="fas fa-layer-group"></i>
        <span>{{ bot_name }} Parser || Designed By LoCCai</span>
      </div>
      <div class="footer-info">
        <span>{{ result.url }}</span>
        {% if rendering_time %}
        <span style="margin-left: 15px; color: rgba(255,255,255,0.6); font-size: 11px;">
          <i class="fas fa-clock" style="margin-right: 4px;"></i>
          <span>Rendering at {{ rendering_time }}</span>
        </span>
        {% endif %}
      </div>
    </div>
  </div>
</body>

</html>